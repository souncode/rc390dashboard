void drawRpmBar(int rpmValue, bool valid)
{
  bool rpmWarning = valid && rpmValue >= rpmRedLimit;
  uint16_t lockColor = rpmLockFlash ? ST77XX_WHITE : ST77XX_RED;
  const UiRect &warnRect = uiLayout[UI_RPM_WARN];
  const UiRect &barRect = uiLayout[UI_RPM_BAR];
  const UiRect &valueRect = uiLayout[UI_RPM_VALUE];
  // restore/modify only the changed sub-region of the bar to avoid full redraw flicker
  int oldRpm = uiCache.rpm;
  int oldLitW = (oldRpm == INVALID_VAL) ? -1 : map(constrain(oldRpm, 0, 16000), 0, 16000, 0, barRect.w);
  int newLitW = valid ? map(constrain(rpmValue, 0, 16000), 0, 16000, 0, barRect.w) : 0;

  // handle warn area minimal update: only redraw text/border when state requires it
  if (rpmWarning)
  {
    tft.setTextSize(1);
    tft.setTextColor(rpmLockFlash ? ST77XX_WHITE : ST77XX_RED, rpmLockFlash ? ST77XX_RED : ST77XX_BLACK);
    // draw a small background block behind the text to reduce the need for full region redraw
    int txtW = 40;
    int txtH = min(14, (int)warnRect.h);
    int tx = warnRect.x + 8;
    int ty = warnRect.y + ((warnRect.h - txtH) / 2);
    // restore the tiny text background from dashboard bitmap
    drawDashboardRegion(tx, ty, txtW, txtH);
    tft.setCursor(tx + 2, ty + 2);
    tft.print("LOCK");
  }

  // If we don't have previous value, fallback to full region restore for bar + value
  if (oldLitW < 0)
  {
    drawDashboardRegion(barRect.x, barRect.y, barRect.w, barRect.h);
    drawDashboardRegion(valueRect.x, valueRect.y, valueRect.w, valueRect.h);
  }
  else
  {
    // If new lit area expanded, restore the newly exposed area from dashboard (it was previously covered)
    if (newLitW > oldLitW)
    {
      int restoreX = barRect.x + oldLitW;
      int restoreW = newLitW - oldLitW;
      if (restoreW > 0)
        drawDashboardRegion(restoreX, barRect.y, restoreW, barRect.h);
    }
    // If new lit area shrank, fill the newly covered region with black (mask)
    else if (newLitW < oldLitW)
    {
      int coverX = barRect.x + newLitW;
      int coverW = oldLitW - newLitW;
      if (coverW > 0)
        tft.fillRect(coverX, barRect.y, coverW, barRect.h, ST77XX_BLACK);
    }
  }

  // ensure right-side cover (unlit area) is hidden (fix coverage edge cases)
  if (newLitW < barRect.w)
  {
    int coverX = barRect.x + newLitW;
    int coverW = barRect.w - newLitW;
    tft.fillRect(coverX, barRect.y, coverW, barRect.h, ST77XX_BLACK);
  }

  // always restore numeric area before drawing digits to avoid overlap
  drawDashboardRegion(valueRect.x, valueRect.y, valueRect.w, valueRect.h);

  // draw border/bottom line for warning if needed
  if (rpmWarning)
  {
    uint16_t lockColorLocal = rpmLockFlash ? ST77XX_WHITE : ST77XX_RED;
    tft.drawRect(barRect.x - 1, barRect.y - 1, barRect.w + 2, barRect.h + 2, lockColorLocal);
    tft.drawFastHLine(barRect.x, barRect.y + barRect.h + 1, barRect.w, lockColorLocal);
  }

  char buf[12];
  if (valid)
    snprintf(buf, sizeof(buf), "%d", rpmValue);
  else
    strcpy(buf, "---");
  {
