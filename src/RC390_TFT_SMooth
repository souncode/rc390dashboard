// =========================
// Setup DEBUG
// =========================
void setup()
{
  Serial.begin(115200);
  delay(1000);

  // seed random for simulation mode
  randomSeed(micros());

  dbg("STEP 1: boot ok");

  pinMode(CAN_CS, OUTPUT);
  pinMode(CAN_INT, INPUT_PULLUP);
  pinMode(TFT_CS, OUTPUT);
  pinMode(TOUCH_CS, OUTPUT);
  pinMode(SD_CS, OUTPUT);

  digitalWrite(CAN_CS, HIGH);
  digitalWrite(TFT_CS, HIGH);
  digitalWrite(TOUCH_CS, HIGH);
  digitalWrite(SD_CS, HIGH);

  dbg("STEP 2: pin ok");

  loadConfig();
  dbg("STEP 2B: config ok");

  SPI.begin(SPI_SCK, SPI_MISO, SPI_MOSI);
  dbg("STEP 3: SPI ok");

  dbg("STEP 4: before TFT");
  initTFT();
  dbg("STEP 5: after TFT");

  updateScreenOptimized(true);
  dbg("STEP 6: screen drawn");

  dbg("STEP 7: before MCP reset");
  deselectAllSPI();
  mcp2515.reset();
  dbg("STEP 8: after MCP reset");

  mcp2515.setBitrate(CAN_SPEED, MCP_CLOCK);
  dbg("STEP 9: bitrate ok");

  mcp2515.setNormalMode();
  dbg("STEP 10: normal mode ok");

  WiFi.mode(WIFI_AP);
  IPAddress local_ip(192, 168, 1, 82);
  IPAddress gateway(192, 168, 1, 82);
  IPAddress subnet(255, 255, 255, 0);
  WiFi.softAPConfig(local_ip, gateway, subnet);
  dbg("STEP 11: wifi config ok");

  bool apOk;
  if (strlen(AP_PASS) >= 8)
    apOk = WiFi.softAP(AP_SSID, AP_PASS);
  else
    apOk = WiFi.softAP(AP_SSID);

  if (apOk)
    dbg("STEP 12: hotspot started");
  else
    dbg("STEP 12: hotspot failed");

  server.on("/", handleRoot);
  server.on("/background.bmp", handleBackgroundBmp);
  server.on("/api/data", handleApiData);
  server.on("/api/config", handleApiConfig);
  server.onNotFound(handleNotFound);
  server.begin();

  dbg("STEP 13: web ok");
  dbg("SETUP DONE");
}

// =========================
// Loop
// =========================
void loop()
{
  server.handleClient();

  if (digitalRead(CAN_INT) == LOW)
  {
    deselectAllSPI();
    while (mcp2515.readMessage(&rxFrame) == MCP2515::ERROR_OK)
    {
      decodeOBD(rxFrame);
      decodeCustomFrames(rxFrame);
    }
  }

  if (!simulationEnabled)
    requestScheduler();

  if (gotGear && (millis() - lastGearMs > GEAR_HOLD_MS))
  {
    // giu gia tri cu
  }

  updateScreenOptimized();

  if (millis() - lastPrint >= 1000)
  {
    Serial.print("RPM=");
    Serial.print(gotRPM ? String((int)rpm) : "---");
    Serial.print(" | SPD=");
    Serial.print(gotSPD ? String(speedKmh) : "---");
    Serial.print(" | ECT=");
    Serial.print(gotECT ? String(coolantC) : "---");
    Serial.print(" | IAT=");
    Serial.print(gotIAT ? String(iatC) : "---");
    Serial.print(" | MAP=");
    Serial.print(gotMAP ? String(mapKpa) : "---");
    Serial.print(" | TPS=");
    Serial.print(gotTPS ? String(tpsPercent, 1) : "---");
    Serial.print(" | FUEL=");
    Serial.print(gotFuel ? String(fuelPercent, 1) : "---");
    Serial.print(" | GEAR=");
    Serial.println(gearTextC());

    lastPrint = millis();
  }
}
