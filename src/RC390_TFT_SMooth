void updateScreenOptimized(bool force = false)
{
  unsigned long now = millis();
  if (!force && (now - lastScreen < SCREEN_INTERVAL_MS_FAST))
    return;
  lastScreen = now;

  bool canAlive = (now - lastDataMs) < 2000;

  if (pendingFullRedraw)
  {
    speedFullscreenActive = false;
    drawStaticDashboard();
    invalidateUiCache();
    pendingFullRedraw = false;
    force = true;
  }

  int rpm_i = gotRPM ? (int)rpm : INVALID_VAL;
  // smooth displayed speed using exponential smoothing
  int spd_i = INVALID_VAL;
  if (gotSPD)
  {
    if (!isfinite(displayedSpeed))
    {
      displayedSpeed = (float)speedKmh;
    }
    else
    {
      displayedSpeed += (float)(speedKmh - (int)(displayedSpeed + 0.5f)) * SPEED_SMOOTH_ALPHA;
    }
    spd_i = (int)(displayedSpeed + 0.5f);
  }
  else
  {
    displayedSpeed = NAN;
  }
  int topspd_i = topSpeedKmh;
  int ect_i = gotECT ? coolantC : INVALID_VAL;
  int iat_i = gotIAT ? iatC : INVALID_VAL;
  int map_i = gotMAP ? mapKpa : INVALID_VAL;
  int gear_i = gotGear ? gear : INVALID_VAL;
  int tps10_i = gotTPS ? (int)(tpsPercent * 10.0f + 0.5f) : INVALID_VAL;
  int fuel10_i = gotFuel ? (int)(fuelPercent * 10.0f + 0.5f) : INVALID_VAL;
  int can_i = canAlive ? 1 : 0;
  bool rpmLockActive = gotRPM && rpm_i >= rpmRedLimit;
  bool rpmLockFlashChanged = false;

  if (rpmLockActive)
  {
    if (now - lastRpmLockFlashMs >= RPM_LOCK_FLASH_MS)
    {
      rpmLockFlash = !rpmLockFlash;
      lastRpmLockFlashMs = now;
      rpmLockFlashChanged = true;
    }
  }
  else if (rpmLockFlash)
  {
    rpmLockFlash = false;
    rpmLockFlashChanged = true;
  }
  if (rpmLockActive != rpmLockActiveLast)
  {
    rpmLockFlashChanged = true;
    rpmLockActiveLast = rpmLockActive;
  }

  char buf[20];

  deselectAllSPI();

  bool speedFullscreen = gotSPD && speedKmh > speedFullscreenLimit;
  if (speedFullscreen)
  {
    if (!speedFullscreenActive || needsRedraw(uiCache.spd, spd_i, SPD_REDRAW_DELTA, force))
    {
      drawFullScreenSpeed(spd_i, gotSPD);
      uiCache.spd = spd_i;
    }
    speedFullscreenActive = true;
    return;
  }

  if (speedFullscreenActive)
  {
    speedFullscreenActive = false;
    drawStaticDashboard();
    invalidateUiCache();
    force = true;
    fullSpeedBgDrawn = false;
  }

  if (rpmLockFlashChanged || needsRedraw(uiCache.rpm, rpm_i, RPM_REDRAW_DELTA, force))
  {
    drawRpmBar(rpm_i, gotRPM);
    uiCache.rpm = rpm_i;
  }

  if (needsRedraw(uiCache.spd, spd_i, SPD_REDRAW_DELTA, force))
  {
    // only update numeric and small gauge slice to reduce full-region redraw
    const UiRect &r = uiLayout[UI_SPEED];
    drawSpeedValue(spd_i, gotSPD);
    uiCache.spd = spd_i;
  }

  if (force || uiCache.gear != gear_i)
  {
    drawGearValue(gear, gotGear);
    uiCache.gear = gear_i;
  }

  if (force || uiCache.ect != ect_i)
  {
    if (gotECT)
      snprintf(buf, sizeof(buf), "%d", ect_i);
    else
      strcpy(buf, "---");
    drawSensorValue(0, buf, DASH_CYAN, gotECT ? map(constrain(ect_i, 40, 120), 40, 120, 0, 46) : 0);
    uiCache.ect = ect_i;
  }

  if (force || uiCache.iat != iat_i)
  {
    if (gotIAT)
      snprintf(buf, sizeof(buf), "%d", iat_i);
    else
      strcpy(buf, "---");
    drawSensorValue(1, buf, DASH_CYAN, gotIAT ? map(constrain(iat_i, 0, 80), 0, 80, 0, 46) : 0);
    uiCache.iat = iat_i;
  }

  if (force || uiCache.map != map_i)
  {
    if (gotMAP)
      snprintf(buf, sizeof(buf), "%d", map_i);
    else
      strcpy(buf, "---");
    drawSensorValue(2, buf, DASH_CYAN, gotMAP ? map(constrain(map_i, 0, 120), 0, 120, 0, 46) : 0);
    uiCache.map = map_i;
  }

  if (needsRedraw(uiCache.tps10, tps10_i, TPS_REDRAW_DELTA10, force))
  {
    if (gotTPS)
      snprintf(buf, sizeof(buf), "%d.%d", tps10_i / 10, abs(tps10_i % 10));
    else
      strcpy(buf, "---");
    drawSensorValue(3, buf, ST77XX_GREEN, gotTPS ? map(constrain(tps10_i, 0, 1000), 0, 1000, 0, 46) : 0);
    uiCache.tps10 = tps10_i;
  }

  if (needsRedraw(uiCache.fuel10, fuel10_i, FUEL_REDRAW_DELTA10, force))
  {
    if (gotFuel)
      snprintf(buf, sizeof(buf), "%d.%d", fuel10_i / 10, abs(fuel10_i % 10));
    else
      strcpy(buf, "---");
    drawSensorValue(4, buf, DASH_ORANGE, gotFuel ? map(constrain(fuel10_i, 0, 1000), 0, 1000, 0, 46) : 0);
    uiCache.fuel10 = fuel10_i;
  }
  if (needsRedraw(uiCache.topspd, topspd_i, SPD_REDRAW_DELTA, force))
  {
    drawTopSpeedValue(topspd_i, gotSPD);
    uiCache.topspd = topspd_i;
  }
  if (force || uiCache.canAlive != can_i)
  {
    drawStatusBar(canAlive);
    uiCache.canAlive = can_i;
  }
}
