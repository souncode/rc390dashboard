    document.getElementById('iat').textContent = d.gotIAT ? d.iat : '---';
    document.getElementById('map').textContent = d.gotMAP ? d.map : '---';
    document.getElementById('fuel').textContent = d.gotFuel ? d.fuel : '---';
    document.getElementById('gear').textContent =
      d.gotGear ? (d.gear === 0 ? 'N' : d.gear) : '---';

    let statusText = "Hotspot OK | ";
    statusText += d.canAlive ? "CAN OK" : "CAN timeout";
    statusText += " | IP: " + d.ip;
    document.getElementById('status').textContent = statusText;

    if (!configLoaded) {
      loadConfigUi();
    }
    // update marker bars if present
    try {
      const scale = screenScale();
      ['ect','iat','map','tps'].forEach(id => {
        const marker = document.querySelector('#screenWrap .marker[data-id="' + id + '"]');
        if (!marker) return;
        const p = layout[id] || {w: marker.clientWidth/scale};
        let pct = 0;
        if (id === 'ect') {
          pct = d.gotECT ? Math.max(0, Math.min(100, (d.coolant - 40) * 100 / (120 - 40))) : 0;
        } else if (id === 'iat') {
          pct = d.gotIAT ? Math.max(0, Math.min(100, (d.iat) * 100 / 80)) : 0;
        } else if (id === 'map') {
          pct = d.gotMAP ? Math.max(0, Math.min(100, (d.map) * 100 / 120)) : 0;
        } else if (id === 'tps') {
          pct = d.gotTPS ? Math.max(0, Math.min(100, d.tps)) : 0;
        }
        const bar = marker.querySelector('.bar');
        if (bar) {
          const fullW = marker.clientWidth; // already scaled in renderLayout
          const w = Math.round(fullW * pct / 100);
          bar.style.width = w + 'px';
          bar.style.top = '2px';
          bar.style.height = Math.max(6, Math.round(marker.clientHeight * 0.18)) + 'px';
        }
      });
    } catch(e) {}
  } catch (e) {
    document.getElementById('status').textContent = 'Web update error';
  }
}

