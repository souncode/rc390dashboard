void printCentered(int x, int y, int w, int h, const char *text, uint16_t color, uint8_t size)
{
  tft.setFont();
  tft.setTextSize(size);
  tft.setTextColor(color, ST77XX_BLACK);

  int16_t x1, y1;
  uint16_t tw, th;
  tft.getTextBounds(text, 0, 0, &x1, &y1, &tw, &th);

  int tx = x + (w - tw) / 2;
  int ty = y + (h - th) / 2;
  if (tx < x + 2)
    tx = x + 2;
  if (ty < y + 2)
    ty = y + 2;

