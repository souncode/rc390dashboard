void drawSevenSegment(int x, int y, int w, int h, int t, uint8_t mask, uint16_t color)
{
  int mid = y + h / 2 - t / 2;
  int vh = h / 2 - t;

  if (mask & 0x01)
    tft.fillRoundRect(x + t, y, w - 2 * t, t, t / 2, color);
  if (mask & 0x02)
    tft.fillRoundRect(x + w - t, y + t, t, vh, t / 2, color);
  if (mask & 0x04)
    tft.fillRoundRect(x + w - t, y + h / 2, t, vh, t / 2, color);
  if (mask & 0x08)
    tft.fillRoundRect(x + t, y + h - t, w - 2 * t, t, t / 2, color);
  if (mask & 0x10)
    tft.fillRoundRect(x, y + h / 2, t, vh, t / 2, color);
  if (mask & 0x20)
    tft.fillRoundRect(x, y + t, t, vh, t / 2, color);
  if (mask & 0x40)
    tft.fillRoundRect(x + t, mid, w - 2 * t, t, t / 2, color);
}

uint8_t sevenSegmentMask(char c)
{
  switch (c)
  {
  case '0':
    return 0x3F;
  case '1':
    return 0x06;
  case '2':
    return 0x5B;
  case '3':
    return 0x4F;
  case '4':
    return 0x66;
  case '5':
    return 0x6D;
  case '6':
    return 0x7D;
  case '7':
    return 0x07;
  case '8':
    return 0x7F;
  case '9':
    return 0x6F;
  case '-':
    return 0x40;
  default:
    return 0;
  }
}

int sevenTextWidth(const char *text, int digitW, int dotW, int gap)
{
  int width = 0;
  for (int i = 0; text[i]; i++)
  {
    width += (text[i] == '.') ? dotW : digitW;
    if (text[i + 1])
      width += gap;
  }
  return width;
}

void drawSevenText(int x, int y, const char *text, int digitW, int digitH, int t, int gap, uint16_t color)
{
  int cx = x;
  int dotW = t + 3;
  for (int i = 0; text[i]; i++)
  {
    char c = text[i];
    if (c == '.')
    {
      tft.fillCircle(cx + dotW / 2, y + digitH - t / 2, max(1, t / 2), color);
      cx += dotW + gap;
      continue;
    }

    uint8_t mask = sevenSegmentMask(c);
    if (mask)
      drawSevenSegment(cx, y, digitW, digitH, t, mask, color);
    else if (c == 'N')
    {
      tft.fillRoundRect(cx, y, t, digitH, t / 2, color);
      tft.fillRoundRect(cx + digitW - t, y, t, digitH, t / 2, color);
      tft.drawLine(cx + t, y + 2, cx + digitW - t - 1, y + digitH - 3, color);
      tft.drawLine(cx + t + 1, y + 2, cx + digitW - t, y + digitH - 3, color);
    }
    cx += digitW + gap;
  }
}

void drawSevenTextCentered(int x, int y, int w, int h, const char *text, int digitW, int digitH, int t, int gap, uint16_t color)
{
  int dotW = t + 3;
  int tw = sevenTextWidth(text, digitW, dotW, gap);
  int tx = x + (w - tw) / 2;
  int ty = y + (h - digitH) / 2;
  if (tx < x)
    tx = x;
  if (ty < y)
    ty = y;
  drawSevenText(tx, ty, text, digitW, digitH, t, gap, color);
}

void computeSevenParamsForRect(const UiRect &r, int baseDigitW, int baseDigitH, int baseT, int baseGap, int &digitW, int &digitH, int &t, int &gap)
{
  float sx = (float)r.w / (float)baseDigitW;
  float sy = (float)r.h / (float)baseDigitH;
  float s = min(sx, sy);
  if (s < 0.25f)
    s = 0.25f;
  digitW = max(3, (int)(baseDigitW * s));
  digitH = max(6, (int)(baseDigitH * s));
  t = max(1, (int)(baseT * s));
  gap = max(1, (int)(baseGap * s));
}

