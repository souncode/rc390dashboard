void putLe16(uint8_t *buf, int idx, uint16_t value)
{
  buf[idx] = value & 0xFF;
  buf[idx + 1] = (value >> 8) & 0xFF;
}

void putLe32(uint8_t *buf, int idx, uint32_t value)
{
  buf[idx] = value & 0xFF;
  buf[idx + 1] = (value >> 8) & 0xFF;
  buf[idx + 2] = (value >> 16) & 0xFF;
  buf[idx + 3] = (value >> 24) & 0xFF;
}

void handleBackgroundBmp()
{
  const uint16_t w = DASHBOARD_BG_W;
  const uint16_t h = DASHBOARD_BG_H;
  const uint16_t rowBytes = w * 3;
  const uint32_t pixelBytes = (uint32_t)rowBytes * h;
  const uint32_t fileBytes = 54 + pixelBytes;

  uint8_t header[54] = {0};
  header[0] = 'B';
  header[1] = 'M';
  putLe32(header, 2, fileBytes);
  putLe32(header, 10, 54);
  putLe32(header, 14, 40);
  putLe32(header, 18, w);
  putLe32(header, 22, h);
  putLe16(header, 26, 1);
  putLe16(header, 28, 24);
  putLe32(header, 34, pixelBytes);

  server.setContentLength(fileBytes);
  server.send(200, "image/bmp", "");
  server.sendContent((const char *)header, sizeof(header));

  static uint8_t row[320 * 3];
  for (int y = h - 1; y >= 0; y--)
  {
    for (int x = 0; x < w; x++)
    {
      uint16_t c = pgm_read_word(&DASHBOARD_BG_BITMAP[y * w + x]);
      uint8_t r = ((c >> 11) & 0x1F) * 255 / 31;
      uint8_t g = ((c >> 5) & 0x3F) * 255 / 63;
      uint8_t b = (c & 0x1F) * 255 / 31;
      int idx = x * 3;
      row[idx] = b;
      row[idx + 1] = g;
      row[idx + 2] = r;
    }
    server.sendContent((const char *)row, rowBytes);
  }
}

void handleApiConfig()
{
  bool tpsCalOk = true;

  if (server.method() == HTTP_POST)
  {
    bool layoutChanged = false;
    if (server.hasArg("rpmLimit"))
      rpmRedLimit = constrain(server.arg("rpmLimit").toInt(), 1000, 16000);
    if (server.hasArg("speedLimit"))
      speedFullscreenLimit = constrain(server.arg("speedLimit").toInt(), 1, 300);
    if (server.hasArg("tpsMin"))
      tpsCalMin = server.arg("tpsMin").toFloat();
    if (server.hasArg("tpsMax"))
      tpsCalMax = server.arg("tpsMax").toFloat();
    if (server.hasArg("tpsCalibrate"))
    {
      if (gotTPS)
      {
        String point = server.arg("tpsCalibrate");
        if (point == "min")
          tpsCalMin = tpsRawPercent;
        else if (point == "max")
          tpsCalMax = tpsRawPercent;
      }
      else
      {
        tpsCalOk = false;
      }
    }
    if (server.hasArg("layoutReset"))
    {
      resetLayoutDefaults();
      layoutChanged = true;
    }
    if (server.hasArg("simMode"))
    {
      simulationEnabled = server.arg("simMode").toInt() != 0;
      prefs.putInt("simMode", simulationEnabled ? 1 : 0);
    }
    for (int i = 0; i < UI_LAYOUT_COUNT; i++)
    {
      String xKey = String("x_") + UI_LAYOUT_DEFS[i].id;
      String yKey = String("y_") + UI_LAYOUT_DEFS[i].id;
      String wKey = String("w_") + UI_LAYOUT_DEFS[i].id;
      String hKey = String("h_") + UI_LAYOUT_DEFS[i].id;
      if (server.hasArg(xKey) && server.hasArg(yKey))
      {
        uiLayout[i].x = server.arg(xKey).toInt();
        uiLayout[i].y = server.arg(yKey).toInt();
        if (server.hasArg(wKey))
          uiLayout[i].w = server.arg(wKey).toInt();
        if (server.hasArg(hKey))
          uiLayout[i].h = server.arg(hKey).toInt();
        // optional bar positioning
        String bt = String("barTop_") + UI_LAYOUT_DEFS[i].id;
        String bh = String("barH_") + UI_LAYOUT_DEFS[i].id;
        if (server.hasArg(bt))
          uiLayout[i].barTop = server.arg(bt).toInt();
        if (server.hasArg(bh))
          uiLayout[i].barH = server.arg(bh).toInt();
        clampUiRect(uiLayout[i]);
        layoutChanged = true;
      }
    }

    normalizeTpsCalibration();

    prefs.putInt("rpmLimit", rpmRedLimit);
    prefs.putInt("spdLimit", speedFullscreenLimit);
    prefs.putFloat("tpsMin", tpsCalMin);
    prefs.putFloat("tpsMax", tpsCalMax);
    if (layoutChanged)
    {
      saveLayoutConfig();
      pendingFullRedraw = true;
    }
    invalidateUiCache();
  }

  server.send(200, "application/json", configJson(tpsCalOk));
}

void handleApiData()
{
  bool canAlive = (millis() - lastDataMs) < 2000;

  // if simulation enabled, generate synthetic telemetry and mark data as present
  if (simulationEnabled)
  {
    lastDataMs = millis();
    // simple random ranges for simulation
    rpm = random(0, 12001);
    speedKmh = random(0, 221);
    if (speedKmh > topSpeedKmh)
      topSpeedKmh = speedKmh;
    coolantC = random(40, 101);
    iatC = random(0, 81);
    mapKpa = random(0, 121);
    int tps10 = random(0, 1001);
    tpsRawPercent = (tps10 / 10.0f) * 255.0f / 100.0f; // approximate raw
    tpsPercent = tps10 / 10.0f;
    fuelPercent = random(0, 1001) / 10.0f;
    gear = random(0, 7);

    gotRPM = true;
    gotSPD = true;
    gotECT = true;
    gotIAT = true;
    gotMAP = true;
    gotTPS = true;
    gotFuel = true;
    gotGear = true;

    canAlive = true;
  }

  String json;
  json.reserve(512);
  json += "{";
  json += "\"rpm\":" + String((int)rpm) + ",";
  json += "\"speed\":" + String(speedKmh) + ",";
  json += "\"coolant\":" + String(coolantC) + ",";
  json += "\"iat\":" + String(iatC) + ",";
  json += "\"map\":" + String(mapKpa) + ",";
  json += "\"tpsRaw\":" + String(tpsRawPercent, 1) + ",";
  json += "\"tps\":" + String(tpsPercent, 1) + ",";
  json += "\"fuel\":" + String(fuelPercent, 1) + ",";
  json += "\"gear\":" + String(gear) + ",";
  json += "\"gotRPM\":" + String(gotRPM ? "true" : "false") + ",";
  json += "\"gotSPD\":" + String(gotSPD ? "true" : "false") + ",";
  json += "\"gotECT\":" + String(gotECT ? "true" : "false") + ",";
  json += "\"gotIAT\":" + String(gotIAT ? "true" : "false") + ",";
  json += "\"gotMAP\":" + String(gotMAP ? "true" : "false") + ",";
  json += "\"gotTPS\":" + String(gotTPS ? "true" : "false") + ",";
  json += "\"gotFuel\":" + String(gotFuel ? "true" : "false") + ",";
  json += "\"gotGear\":" + String(gotGear ? "true" : "false") + ",";
  json += "\"canAlive\":" + String(canAlive ? "true" : "false") + ",";
  json += "\"rpmLimit\":" + String(rpmRedLimit) + ",";
  json += "\"speedLimit\":" + String(speedFullscreenLimit) + ",";
  json += "\"tpsMin\":" + String(tpsCalMin, 1) + ",";
  json += "\"tpsMax\":" + String(tpsCalMax, 1) + ",";
  json += "\"ip\":\"" + WiFi.softAPIP().toString() + "\"";
  json += "}";
  server.send(200, "application/json", json);
}

