bool needsRedraw(int oldVal, int newVal, int delta, bool force = false)
{
  if (force)
    return true;
  if (oldVal == INVALID_VAL || newVal == INVALID_VAL)
    return oldVal != newVal;
  return abs(newVal - oldVal) >= delta;
}

