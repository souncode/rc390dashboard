void drawSpeedValue(int spdValue, bool valid)
{
  const UiRect &r = uiLayout[UI_SPEED];
  char buf[8];
  if (valid)
    snprintf(buf, sizeof(buf), "%d", spdValue);
  else
    strcpy(buf, "---");

  int dW, dH, dt, dg;
  computeSevenParamsForRect(r, 30, 52, 6, 4, dW, dH, dt, dg);
  int dotW = dt + 3;
  int tw = sevenTextWidth(buf, dW, dotW, dg);
  int tx = r.x + (r.w - tw) / 2;
  int ty = r.y + (r.h - dH) / 2;
  if (tx < r.x)
    tx = r.x;
  if (ty < r.y)
    ty = r.y;

  // ensure cached background for numeric area
  if (!speedBgBuf || speedBgW != r.w || speedBgH != dH)
  {
    // free old
    if (speedBgBuf)
      free(speedBgBuf);
    speedBgW = r.w;
    speedBgH = dH;
    speedBgBuf = (uint16_t *)malloc(sizeof(uint16_t) * speedBgW * speedBgH);
    if (speedBgBuf)
    {
      for (int yy = 0; yy < speedBgH; yy++)
      {
        for (int xx = 0; xx < speedBgW; xx++)
        {
          int sx = r.x + xx;
          int sy = r.y + yy;
          if (sx >= 0 && sx < DASHBOARD_BG_W && sy >= 0 && sy < DASHBOARD_BG_H)
            speedBgBuf[yy * speedBgW + xx] = pgm_read_word(&DASHBOARD_BG_BITMAP[sy * DASHBOARD_BG_W + sx]);
          else
            speedBgBuf[yy * speedBgW + xx] = ST77XX_BLACK;
        }
      }
    }
  }

  // compute previous text width and position
  int prevTw = sevenTextWidth(prevSpeedText, dW, dotW, dg);
  int prevTx = r.x + (r.w - prevTw) / 2;

  // if alignment/width changed or no previous text, restore full numeric area
  if (prevTw == 0 || prevTx != tx)
  {
    // full restore using cached bitmap
    if (speedBgBuf)
    {
      tft.drawRGBBitmap(r.x, ty, speedBgBuf, speedBgW, speedBgH);
    }
    else
    {
      drawDashboardRegion(r.x, r.y, r.w, r.h);
    }
    // draw all characters
    int cx2 = tx;
    for (int i = 0; buf[i]; i++)
    {
      char c = buf[i];
      int charW = (c == '.') ? dotW : dW;
      if (c == '.')
      {
        tft.fillCircle(cx2 + dotW / 2, ty + dH - dt / 2, max(1, dt / 2), valid ? ST77XX_WHITE : DASH_DIM);
      }
      else
      {
        uint8_t mask = sevenSegmentMask(c);
        if (mask)
          drawSevenSegment(cx2, ty, dW, dH, dt, mask, valid ? ST77XX_WHITE : DASH_DIM);
        else if (c == 'N')
        {
          tft.fillRoundRect(cx2, ty, dt, dH, dt / 2, valid ? ST77XX_WHITE : DASH_DIM);
          tft.fillRoundRect(cx2 + dW - dt, ty, dt, dH, dt / 2, valid ? ST77XX_WHITE : DASH_DIM);
          tft.drawLine(cx2 + dt, ty + 2, cx2 + dW - dt - 1, ty + dH - 3, valid ? ST77XX_WHITE : DASH_DIM);
          tft.drawLine(cx2 + dt + 1, ty + 2, cx2 + dW - dt, ty + dH - 3, valid ? ST77XX_WHITE : DASH_DIM);
        }
      }
      cx2 += charW + dg;
    }
  }
  else
  {
    // same alignment: clear trailing area if new width is smaller
    if (tw < prevTw)
    {
      drawDashboardRegion(tx + tw, ty, prevTw - tw, dH);
    }

    int cx3 = tx;
    for (int i = 0; buf[i]; i++)
    {
      char c = buf[i];
      int charW = (c == '.') ? dotW : dW;
      if (prevSpeedText[i] != c)
      {
        drawDashboardRegion(cx3, ty, charW, dH);
        if (c == '.')
        {
          tft.fillCircle(cx3 + dotW / 2, ty + dH - dt / 2, max(1, dt / 2), valid ? ST77XX_WHITE : DASH_DIM);
        }
        else
        {
          uint8_t mask = sevenSegmentMask(c);
          if (mask)
            drawSevenSegment(cx3, ty, dW, dH, dt, mask, valid ? ST77XX_WHITE : DASH_DIM);
          else if (c == 'N')
          {
            tft.fillRoundRect(cx3, ty, dt, dH, dt / 2, valid ? ST77XX_WHITE : DASH_DIM);
            tft.fillRoundRect(cx3 + dW - dt, ty, dt, dH, dt / 2, valid ? ST77XX_WHITE : DASH_DIM);
            tft.drawLine(cx3 + dt, ty + 2, cx3 + dW - dt - 1, ty + dH - 3, valid ? ST77XX_WHITE : DASH_DIM);
            tft.drawLine(cx3 + dt + 1, ty + 2, cx3 + dW - dt, ty + dH - 3, valid ? ST77XX_WHITE : DASH_DIM);
          }
        }
      }
      cx3 += charW + dg;
    }
  }

  // copy new text into prev buffer
  strncpy(prevSpeedText, buf, sizeof(prevSpeedText) - 1);
  prevSpeedText[sizeof(prevSpeedText) - 1] = '\0';
}

