<script>
let configLoaded = false;
let layout = {};
let defaultLayout = {};
let activeMarker = null;
let activeId = '';
let activeBar = null;
let activeBarId = '';

function applyConfig(d) {
  document.getElementById('rpmLimit').value = d.rpmLimit;
  document.getElementById('speedLimit').value = d.speedLimit;
  document.getElementById('tpsMin').value = d.tpsMin;
  document.getElementById('tpsMax').value = d.tpsMax;
  if (d.simMode !== undefined && document.getElementById('simToggle'))
    document.getElementById('simToggle').checked = d.simMode;
  if (d.layout) {
    layout = d.layout;
    defaultLayout = d.layoutDefault || {};
    renderLayout();
  }
  configLoaded = true;
}

async function loadConfigUi() {
  try {
    const res = await fetch('/api/config?_=' + Date.now());
    applyConfig(await res.json());
  } catch (e) {}
}

function screenScale() {
  const wrap = document.getElementById('screenWrap');
  return wrap.clientWidth / 320;
}

function renderLayout() {
  const wrap = document.getElementById('screenWrap');
  const grid = document.getElementById('coordGrid');
  const palette = document.getElementById('palette');
  wrap.querySelectorAll('.marker').forEach(el => el.remove());
  grid.innerHTML = '';
  if (palette) palette.innerHTML = '';
  const scale = screenScale();

  Object.keys(layout).forEach(id => {
    const p = layout[id];
    const marker = document.createElement('div');
    marker.className = 'marker';
    marker.dataset.id = id;
    marker.textContent = p.label || id;
    // add sensor bar for sensor widgets
    if (id === 'ect' || id === 'iat' || id === 'map' || id === 'tps') {
      const bar = document.createElement('div');
      bar.className = 'bar ' + id;
      bar.id = 'bar_' + id;
      const topPct = (p.barTop !== undefined) ? p.barTop : 0;
      const hPct = (p.barH !== undefined) ? p.barH : Math.max(15, Math.round( (p.h/ (p.h||1)) * 20));
      bar.style.left = '2px';
      // default visible width (20% of marker) so user can see and drag before data arrives
      bar.style.width = Math.max(6, Math.round((p.w * scale) * 0.2)) + 'px';
      bar.style.top = Math.round((topPct / 100) * (p.h * scale)) + 'px';
      bar.style.height = Math.max(6, Math.round((hPct / 100) * (p.h * scale))) + 'px';
      bar.addEventListener('pointerdown', startBarDrag);
      bar.addEventListener('pointerdown', function(ev){ ev.stopPropagation(); });
      marker.appendChild(bar);
    }
    marker.style.left = (p.x * scale) + 'px';
    marker.style.top = (p.y * scale) + 'px';
    marker.style.width = (p.w * scale) + 'px';
    marker.style.height = (p.h * scale) + 'px';
    marker.addEventListener('pointerdown', startDrag);
    marker.addEventListener('wheel', scaleMarker);
    wrap.appendChild(marker);

    const row = document.createElement('div');
    row.className = 'coord-row';
    row.innerHTML = '<span>' + (p.label || id) + '</span>' +
      '<input id="x_' + id + '" type="number" min="0" max="319" value="' + p.x + '">' +
      '<input id="y_' + id + '" type="number" min="0" max="239" value="' + p.y + '">' +
      '<input id="w_' + id + '" type="number" min="4" max="320" value="' + p.w + '">' +
      '<input id="h_' + id + '" type="number" min="4" max="240" value="' + p.h + '">';
    grid.appendChild(row);
    row.querySelectorAll('input').forEach(input => input.addEventListener('change', () => {
      p.w = Math.max(4, Math.min(320, parseInt(document.getElementById('w_' + id).value || '4')));
      p.h = Math.max(4, Math.min(240, parseInt(document.getElementById('h_' + id).value || '4')));
      p.x = Math.max(0, Math.min(320 - p.w, parseInt(document.getElementById('x_' + id).value || '0')));
      p.y = Math.max(0, Math.min(240 - p.h, parseInt(document.getElementById('y_' + id).value || '0')));
      renderLayout();
    }));
  });

  // populate palette with sensor items that can be dragged onto the screen
  if (palette) {
    ['ect','iat','map','tps'].forEach(id => {
      const itm = document.createElement('div');
      itm.className = 'item' + (layout[id] ? ' placed' : '');
      itm.dataset.id = id;
      itm.textContent = id.toUpperCase();
      itm.addEventListener('pointerdown', startPaletteDrag);
      palette.appendChild(itm);
    });
  }
}

function startPaletteDrag(e) {
  const id = e.currentTarget.dataset.id;
  const wrap = document.getElementById('screenWrap');
  if (!wrap) return;
  // ensure layout entry exists
  if (!layout[id]) {
    layout[id] = { x: 0, y: 0, w: 48, h: 18, label: id.toUpperCase() };
  }
  const scale = screenScale();
  const rect = wrap.getBoundingClientRect();
  const p = layout[id];
  // position at pointer location
  p.x = Math.round((e.clientX - rect.left) / scale - p.w / 2);
  p.y = Math.round((e.clientY - rect.top) / scale - p.h / 2);
  p.x = Math.max(0, Math.min(320 - p.w, p.x));
  p.y = Math.max(0, Math.min(240 - p.h, p.y));
  // render layout (creates marker DOM and grid row)
  renderLayout();
  // find rendered marker and start dragging it
  const marker = wrap.querySelector('.marker[data-id="' + id + '"]');
  if (!marker) return;
  activeMarker = marker;
  activeId = id;
  activeMarker.classList.add('active');
  activeMarker.setPointerCapture(e.pointerId);
  activeMarker.addEventListener('pointermove', dragMove);
  activeMarker.addEventListener('pointerup', endDrag);
  activeMarker.addEventListener('pointercancel', endDrag);
  // ensure visual position matches computed coords
  activeMarker.style.left = (p.x * scale) + 'px';
  activeMarker.style.top = (p.y * scale) + 'px';
}

function startDrag(e) {
  activeMarker = e.currentTarget;
  activeId = activeMarker.dataset.id;
  activeMarker.classList.add('active');
  activeMarker.setPointerCapture(e.pointerId);
  activeMarker.addEventListener('pointermove', dragMove);
  activeMarker.addEventListener('pointerup', endDrag);
  activeMarker.addEventListener('pointercancel', endDrag);
}

function startBarDrag(e) {
  e.stopPropagation();
  activeBar = e.currentTarget;
  activeBarId = activeBar.id.replace('bar_','');
  activeBar.classList.add('active');
  activeBar.setPointerCapture(e.pointerId);
  activeBar.addEventListener('pointermove', barDragMove);
  activeBar.addEventListener('pointerup', endBarDrag);
  activeBar.addEventListener('pointercancel', endBarDrag);
}

function barDragMove(e) {
  if (!activeBar) return;
  const marker = document.querySelector('#screenWrap .marker[data-id="' + activeBarId + '"]');
  if (!marker) return;
  const mRect = marker.getBoundingClientRect();
  const p = layout[activeBarId];
  if (!p) return;
  // compute top percentage within marker
  let top = (e.clientY - mRect.top) / mRect.height;
  top = Math.max(0, Math.min(1, top));
  p.barTop = Math.round(top * 100);
  // update DOM
  activeBar.style.top = Math.round(top * mRect.height) + 'px';
}

function endBarDrag(e) {
  if (!activeBar) return;
  activeBar.classList.remove('active');
  activeBar.removeEventListener('pointermove', barDragMove);
  activeBar.removeEventListener('pointerup', endBarDrag);
  activeBar.removeEventListener('pointercancel', endBarDrag);
  activeBar = null;
  activeBarId = '';
}

function dragMove(e) {
  if (!activeMarker || !layout[activeId]) return;
  const wrap = document.getElementById('screenWrap');
  const rect = wrap.getBoundingClientRect();
  const scale = screenScale();
  const p = layout[activeId];
  p.x = Math.round((e.clientX - rect.left) / scale - p.w / 2);
  p.y = Math.round((e.clientY - rect.top) / scale - p.h / 2);
  p.x = Math.max(0, Math.min(320 - p.w, p.x));
  p.y = Math.max(0, Math.min(240 - p.h, p.y));
  activeMarker.style.left = (p.x * scale) + 'px';
  activeMarker.style.top = (p.y * scale) + 'px';
  document.getElementById('x_' + activeId).value = p.x;
  document.getElementById('y_' + activeId).value = p.y;
}

function endDrag(e) {
  if (!activeMarker) return;
  // if dropped inside palette, remove placement
  const palette = document.getElementById('palette');
  if (palette) {
    const pr = palette.getBoundingClientRect();
    if (e.clientX >= pr.left && e.clientX <= pr.right && e.clientY >= pr.top && e.clientY <= pr.bottom) {
      // remove placement
      delete layout[activeId];
      activeMarker.remove();
      activeMarker = null;
      activeId = '';
      renderLayout();
      return;
    }
  }
  activeMarker.classList.remove('active');
  activeMarker.removeEventListener('pointermove', dragMove);
  activeMarker.removeEventListener('pointerup', endDrag);
  activeMarker.removeEventListener('pointercancel', endDrag);
  activeMarker = null;
  activeId = '';
}

function scaleMarker(e) {
  e.preventDefault();
  const id = e.currentTarget.dataset.id;
  const p = layout[id];
  if (!p) return;
  const step = e.deltaY < 0 ? 2 : -2;
  p.w = Math.max(4, Math.min(320, p.w + step * 2));
  p.h = Math.max(4, Math.min(240, p.h + step));
  p.x = Math.max(0, Math.min(320 - p.w, p.x - step));
  p.y = Math.max(0, Math.min(240 - p.h, p.y - Math.round(step / 2)));
  renderLayout();
}

