// CAN / OBD
// =========================
void sendOBDRequest(uint8_t pid)
{
  txFrame.can_id = 0x7DF;
  txFrame.can_dlc = 8;
  txFrame.data[0] = 0x02;
  txFrame.data[1] = 0x01;
  txFrame.data[2] = pid;
  txFrame.data[3] = 0x00;
  txFrame.data[4] = 0x00;
  txFrame.data[5] = 0x00;
  txFrame.data[6] = 0x00;
  txFrame.data[7] = 0x00;
  mcp2515.sendMessage(&txFrame);
}

void requestScheduler()
{
  unsigned long now = millis();

  if (now - lastReqAny < MIN_OBD_REQ_GAP_MS)
    return;

  if (now - lastReqRPM >= RPM_REQ_MS)
  {
    deselectAllSPI();
    sendOBDRequest(PID_RPM);
    lastReqRPM = now;
    lastReqAny = now;
    return;
  }

  if (now - lastReqSPD >= SPD_REQ_MS)
  {
    deselectAllSPI();
    sendOBDRequest(PID_SPD);
    lastReqSPD = now;
    lastReqAny = now;
    return;
  }

  if (now - lastReqTPS >= TPS_REQ_MS)
  {
    deselectAllSPI();
    sendOBDRequest(PID_TPS);
    lastReqTPS = now;
    lastReqAny = now;
    return;
  }

  if (now - lastReqSlow >= SLOW_REQ_MS)
  {
    deselectAllSPI();
    if (slowIdx == 0)
      sendOBDRequest(PID_ECT);
    else if (slowIdx == 1)
      sendOBDRequest(PID_IAT);
    else
      sendOBDRequest(PID_MAP);

    slowIdx++;
    if (slowIdx >= 3)
      slowIdx = 0;
    lastReqSlow = now;
    lastReqAny = now;
    return;
  }

  if (now - lastReqFuel >= FUEL_REQ_MS)
  {
    deselectAllSPI();
    sendOBDRequest(PID_FUEL);
    lastReqFuel = now;
    lastReqAny = now;
    return;
  }
}

void decodeOBD(const can_frame &f)
{
  if (f.can_id < 0x7E8 || f.can_id > 0x7EF)
    return;
  if (f.can_dlc < 4)
    return;
  if (f.data[1] != 0x41)
    return;

  uint8_t pid = f.data[2];
  lastDataMs = millis();

  switch (pid)
  {
  case PID_RPM:
    if (f.can_dlc >= 5)
    {
      int A = f.data[3];
      int B = f.data[4];
      rpm = ((A * 256.0f) + B) / 4.0f;
      gotRPM = true;
    }
    break;

  case PID_SPD:
    speedKmh = f.data[3];
    if (speedKmh > topSpeedKmh)
      topSpeedKmh = speedKmh;
    gotSPD = true;
    break;

  case PID_ECT:
    coolantC = (int)f.data[3] - 40;
    gotECT = true;
    break;

  case PID_IAT:
    iatC = (int)f.data[3] - 40;
    gotIAT = true;
    break;

  case PID_MAP:
    mapKpa = f.data[3];
    gotMAP = true;
    break;

  case PID_TPS:
  {
    tpsRawPercent = f.data[3] * 100.0f / 255.0f;

    tpsPercent =
        (tpsRawPercent - tpsCalMin) *
        100.0f /
        (tpsCalMax - tpsCalMin);

    if (tpsPercent < 0)
      tpsPercent = 0;
    if (tpsPercent > 100)
      tpsPercent = 100;

    gotTPS = true;
  }
  break;

  case PID_FUEL:
    fuelPercent = f.data[3] * 100.0f / 255.0f;
    gotFuel = true;
    break;
  }
}

void decodeCustomFrames(const can_frame &f)
{
  if (f.can_id != 0x540 || f.can_dlc < 8)
    return;

  if (f.data[0] == 0x02 && f.data[6] == 0x01)
  {
    uint8_t v = f.data[3];

    if (v >= 1 && v <= 6)
    {
      gear = v;
      gotGear = true;
      neutralCandidateMs = 0;
      lastGearMs = millis();
      return;
    }

    if (v == 0 && speedKmh == 0)
    {
      if (neutralCandidateMs == 0)
      {
        neutralCandidateMs = millis();
      }
      else if (millis() - neutralCandidateMs >= NEUTRAL_DEBOUNCE_MS)
      {
        gear = 0;
        gotGear = true;
        lastGearMs = millis();
      }
      return;
    }
  }

  if ((f.data[0] == 0x04 || f.data[0] == 0x06) && speedKmh == 0)
  {
    if (neutralCandidateMs == 0)
      neutralCandidateMs = millis();
    return;
  }

  neutralCandidateMs = 0;
}

