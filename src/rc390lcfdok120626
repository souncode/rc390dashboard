// =========================
// TFT helpers
// =========================
bool needsRedraw(int oldVal, int newVal, int delta, bool force = false)
{
  if (force)
    return true;
  if (oldVal == INVALID_VAL || newVal == INVALID_VAL)
    return oldVal != newVal;
  return abs(newVal - oldVal) >= delta;
}

void invalidateUiCache()
{
  uiCache = UiCache();
}

float clampFloat(float value, float minValue, float maxValue)
{
  if (value < minValue)
    return minValue;
  if (value > maxValue)
    return maxValue;
  return value;
}

void normalizeTpsCalibration()
{
  tpsCalMin = clampFloat(tpsCalMin, 0.0f, 100.0f);
  tpsCalMax = clampFloat(tpsCalMax, 0.0f, 100.0f);
  if (tpsCalMin > 99.0f)
    tpsCalMin = 99.0f;
  if (tpsCalMax < tpsCalMin + 1.0f)
    tpsCalMax = tpsCalMin + 1.0f;
}

