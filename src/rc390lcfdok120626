void printCentered(int x, int y, int w, int h, const char *text, uint16_t color, uint8_t size)
{
  tft.setTextSize(size);
  tft.setTextColor(color, ST77XX_BLACK);

  int16_t x1, y1;
  uint16_t tw, th;
  tft.getTextBounds(text, 0, 0, &x1, &y1, &tw, &th);

  int tx = x + (w - tw) / 2;
  int ty = y + (h - th) / 2;
  if (tx < x + 2)
    tx = x + 2;
  if (ty < y + 2)
    ty = y + 2;

  tft.setCursor(tx, ty);
  tft.print(text);
}

void drawPanel(int x, int y, int w, int h, uint16_t color)
{
  const int c = 5;
  tft.fillRect(x + 1, y + 1, w - 2, h - 2, ST77XX_BLACK);
  tft.drawLine(x + c, y, x + w - c - 1, y, color);
  tft.drawLine(x + w - 1, y + c, x + w - 1, y + h - c - 1, color);
  tft.drawLine(x + c, y + h - 1, x + w - c - 1, y + h - 1, color);
  tft.drawLine(x, y + c, x, y + h - c - 1, color);
  tft.drawLine(x, y + c, x + c, y, color);
  tft.drawLine(x + w - c - 1, y, x + w - 1, y + c, color);
  tft.drawLine(x + w - 1, y + h - c - 1, x + w - c - 1, y + h - 1, color);
  tft.drawLine(x + c, y + h - 1, x, y + h - c - 1, color);
}

