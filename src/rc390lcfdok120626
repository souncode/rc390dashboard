void drawRpmBar(int rpmValue, bool valid)
{
  tft.fillRect(64, 42, 188, 14, ST77XX_BLACK);
  tft.fillRect(258, 33, 58, 24, ST77XX_BLACK);

  bool rpmWarning = valid && rpmValue > rpmRedLimit;
  int lit = valid ? map(constrain(rpmValue, 0, 16000), 0, 16000, 0, 32) : 0;
  for (int i = 0; i < 32; i++)
  {
    int x = 64 + i * 6;
    uint16_t color = DASH_DIM;
    if (i < lit)
    {
      if (rpmWarning)
        color = ST77XX_RED;
      else if (i < 16)
        color = ST77XX_GREEN;
      else if (i < 23)
        color = ST77XX_YELLOW;
      else if (i < 27)
        color = DASH_ORANGE;
      else
        color = ST77XX_RED;
    }
    tft.fillRect(x, 42, 4, 14, color);
  }

  char buf[12];
  if (valid)
    snprintf(buf, sizeof(buf), "%d", rpmValue);
  else
    strcpy(buf, "---");
  printCentered(258, 32, 58, 26, buf, valid ? (rpmWarning ? ST77XX_RED : ST77XX_GREEN) : DASH_DIM, 2);
}

